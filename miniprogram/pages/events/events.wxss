.events-page {
  padding: 12px 16px 32px;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  gap: 10px;
  margin-bottom: 16px;
}

.search-input {
  flex: 1;
  height: 40px;
  background: rgba(30, 39, 80, 0.4);
  border: 1px solid rgba(140, 155, 240, 0.15);
  border-radius: 20px;
  padding: 0 16px;
  font-size: 14px;
  color: var(--text-primary);
}

.search-placeholder {
  color: var(--text-disabled);
  font-size: 14px;
}

.search-btn {
  height: 40px;
  line-height: 40px;
  padding: 0 16px;
  background: linear-gradient(135deg, #5E72E4 0%, #7C3AED 100%);
  color: #fff;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 500;
}

/* 过滤标签 */
.filter-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
  white-space: nowrap;
  overflow-x: auto;
}

.filter-tab {
  display: inline-block;
  padding: 6px 16px;
  border-radius: 16px;
  font-size: 13px;
  color: var(--text-tertiary);
  background: rgba(30, 39, 80, 0.3);
  border: 1px solid rgba(140, 155, 240, 0.08);
}

.filter-tab.active {
  color: var(--color-primary-light);
  background: rgba(94, 114, 228, 0.15);
  border-color: rgba(94, 114, 228, 0.3);
}

/* 事件列表 */
.event-card {
  background: rgba(30, 39, 80, 0.4);
  border: 1px solid rgba(140, 155, 240, 0.15);
  border-radius: 10px;
  padding: 14px;
  margin-bottom: 10px;
}

.event-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.event-platform-info {
  display: flex;
  align-items: center;
  gap: 6px;
}

.platform-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

.event-platform {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 4px;
  background: rgba(107, 114, 128, 0.12);
  color: var(--text-tertiary);
}

.event-title {
  font-size: 14px;
  color: var(--text-primary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-all;
}

.event-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8px;
}

.event-author {
  font-size: 12px;
  color: var(--text-tertiary);
}

.event-time {
  font-size: 12px;
  color: var(--text-disabled);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 16px 0;
}

.load-more-text {
  font-size: 13px;
  color: var(--color-primary-light);
}

.load-end {
  color: var(--text-disabled);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60px 0;
}

.loading-text {
  font-size: 14px;
  color: var(--text-tertiary);
}

.empty-text {
  font-size: 14px;
  color: var(--text-disabled);
}

/* 标签 */
.tag-positive {
  color: #10B981;
  background: rgba(16, 185, 129, 0.12);
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
}

.tag-negative {
  color: #EF4444;
  background: rgba(239, 68, 68, 0.12);
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
}

.tag-neutral {
  color: #9CA3AF;
  background: rgba(107, 114, 128, 0.12);
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
}
