.detail-page {
  padding: 16px 16px 32px;
}

.detail-title {
  font-size: 20px;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  display: block;
  margin-bottom: 12px;
}

.detail-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.platform-badge {
  font-size: 11px;
  padding: 3px 10px;
  border-radius: 4px;
  background: rgba(107, 114, 128, 0.12);
  color: var(--text-tertiary);
}

.detail-author {
  font-size: 13px;
  color: var(--text-secondary);
}

.detail-time {
  font-size: 12px;
  color: var(--text-disabled);
}

/* 情感 */
.sentiment-section {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 16px 0;
}

.sentiment-badge {
  font-size: 13px;
  padding: 4px 12px;
  border-radius: 4px;
  font-weight: 500;
}

.sentiment-label {
  font-size: 13px;
  color: var(--text-tertiary);
}

/* 互动数据 */
.engagement-section {
  display: flex;
  justify-content: space-around;
  padding: 16px;
  margin-bottom: 16px;
}

.engagement-item {
  text-align: center;
}

.engagement-value {
  display: block;
  font-size: 20px;
  font-weight: 600;
  color: var(--text-primary);
}

.engagement-label {
  display: block;
  font-size: 12px;
  color: var(--text-tertiary);
  margin-top: 4px;
}

/* 关键词 */
.keywords-section {
  margin-bottom: 16px;
}

.section-title {
  font-size: 14px;
  font-weight: 500;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 8px;
}

.keywords-list {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.keyword-tag {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 4px;
  background: rgba(94, 114, 228, 0.12);
  color: var(--color-primary-light);
  border: 1px solid rgba(94, 114, 228, 0.2);
}

/* 内容 */
.content-section {
  margin-bottom: 16px;
}

.content-title {
  font-size: 14px;
  font-weight: 500;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 8px;
}

.content-body {
  font-size: 14px;
  color: var(--text-primary);
  line-height: 1.7;
  display: block;
}

/* AI 分析 */
.ai-section {
  margin-bottom: 20px;
  border: 1px solid rgba(124, 58, 237, 0.2);
}

.ai-title {
  font-size: 14px;
  font-weight: 500;
  color: #7C3AED;
  display: block;
  margin-bottom: 8px;
}

.ai-body {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.6;
  display: block;
}

/* 原文按钮 */
.source-btn {
  width: 100%;
  margin-top: 8px;
  border-radius: 10px;
}

.source-btn::after {
  border: none;
}

/* 标签 */
.tag-positive {
  color: #10B981;
  background: rgba(16, 185, 129, 0.12);
}

.tag-negative {
  color: #EF4444;
  background: rgba(239, 68, 68, 0.12);
}

.tag-neutral {
  color: #9CA3AF;
  background: rgba(107, 114, 128, 0.12);
}
