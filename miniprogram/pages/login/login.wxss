page {
  background: var(--bg-deep-space);
  min-height: 100vh;
}

.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 32px 32px;
  min-height: 100vh;
}

.login-header {
  margin-bottom: 48px;
  text-align: center;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.logo-title {
  font-size: 28px;
  font-weight: 700;
  background: linear-gradient(135deg, #5E72E4 0%, #7C3AED 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.logo-subtitle {
  font-size: 13px;
  color: var(--text-tertiary);
  margin-top: 8px;
}

.login-form {
  width: 100%;
  max-width: 360px;
}

.input-group {
  margin-bottom: 20px;
}

.input-label {
  display: block;
  font-size: 14px;
  color: var(--text-secondary);
  margin-bottom: 8px;
  font-weight: 500;
}

.input-field {
  width: 100%;
  height: 48px;
  background: rgba(30, 39, 80, 0.4);
  border: 1px solid rgba(140, 155, 240, 0.15);
  border-radius: 10px;
  padding: 0 16px;
  font-size: 15px;
  color: var(--text-primary);
  box-sizing: border-box;
}

.input-placeholder {
  color: var(--text-disabled);
  font-size: 15px;
}

.login-btn {
  width: 100%;
  height: 48px;
  line-height: 48px;
  margin-top: 12px;
  font-size: 16px;
  border-radius: 10px;
}

.login-btn::after {
  border: none;
}

.login-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 24px;
}

.link-text {
  font-size: 14px;
  color: var(--color-primary-light);
}

.login-version {
  position: fixed;
  bottom: 32px;
  font-size: 12px;
  color: var(--text-disabled);
}
