<view class="login-page">
  <view class="login-header">
    <view class="logo-area">
      <text class="logo-icon">&#x1F50D;</text>
      <text class="logo-title">舆情监测系统</text>
      <text class="logo-subtitle">实时舆情 · 智能预警 · 数据分析</text>
    </view>
  </view>

  <view class="login-form">
    <view class="input-group">
      <text class="input-label">用户名</text>
      <input class="input-field" placeholder="请输入用户名" placeholder-class="input-placeholder"
        value="{{username}}" bindinput="onUsernameInput" />
    </view>

    <view class="input-group">
      <text class="input-label">密码</text>
      <input class="input-field" type="password" placeholder="请输入密码" placeholder-class="input-placeholder"
        value="{{password}}" bindinput="onPasswordInput" />
    </view>

    <button class="btn-primary login-btn" bindtap="onLogin" loading="{{loading}}">
      <text wx:if="{{!loading}}">登 录</text>
      <text wx:else>登录中...</text>
    </button>

    <view class="login-footer">
      <text class="link-text" bindtap="onRegister">注册账号</text>
      <text class="link-text" bindtap="onForgotPassword">忘记密码</text>
    </view>
  </view>

  <view class="login-version">v1.0.0</view>
</view>
