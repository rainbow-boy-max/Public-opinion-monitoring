.profile-page {
  padding: 16px 16px 32px;
}

/* 用户信息 */
.user-section {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 20px;
  margin-bottom: 20px;
}

.user-avatar {
  width: 56px;
  height: 56px;
  border-radius: 28px;
  background: linear-gradient(135deg, #5E72E4 0%, #7C3AED 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 22px;
  font-weight: 600;
  color: #ffffff;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 18px;
  font-weight: 600;
  color: var(--text-primary);
}

.user-phone {
  display: block;
  font-size: 13px;
  color: var(--text-tertiary);
  margin-top: 2px;
}

.user-role {
  display: inline-block;
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 4px;
  background: rgba(94, 114, 228, 0.12);
  color: var(--color-primary-light);
  margin-top: 4px;
}

/* 设置 */
.settings-section {
  padding: 4px 16px;
  margin-bottom: 20px;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid var(--border-subtle);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 14px;
  color: var(--text-primary);
}

.setting-switch {
  transform: scale(0.8);
}

/* 操作列表 */
.actions-section {
  margin-bottom: 24px;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  background: rgba(30, 39, 80, 0.4);
  border: 1px solid rgba(140, 155, 240, 0.15);
  border-radius: 10px;
  margin-bottom: 8px;
}

.action-icon {
  font-size: 18px;
  margin-right: 12px;
}

.action-text {
  flex: 1;
  font-size: 14px;
  color: var(--text-primary);
}

.action-arrow {
  font-size: 14px;
  color: var(--text-disabled);
}

/* 版本信息 */
.version-info {
  display: block;
  text-align: center;
  font-size: 12px;
  color: var(--text-disabled);
  margin-bottom: 24px;
}

/* 退出按钮 */
.logout-btn {
  width: 100%;
  height: 48px;
  line-height: 48px;
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: 10px;
  color: #EF4444;
  font-size: 16px;
  font-weight: 500;
  text-align: center;
}

.logout-btn::after {
  border: none;
}
