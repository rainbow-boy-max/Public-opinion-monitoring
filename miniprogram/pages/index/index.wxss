.index-page {
  padding: 20px 16px 32px;
}

/* 头部 */
.header-section {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24px;
}

.greeting-text {
  font-size: 24px;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.date-text {
  font-size: 13px;
  color: var(--text-tertiary);
  margin-top: 4px;
  display: block;
}

.time-area {
  text-align: right;
}

.time-text {
  font-size: 32px;
  font-weight: 300;
  color: var(--text-secondary);
  font-variant-numeric: tabular-nums;
}

/* 统计卡片网格 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 24px;
}

.stat-card {
  position: relative;
  background: rgba(30, 39, 80, 0.4);
  border: 1px solid rgba(140, 155, 240, 0.15);
  border-radius: 12px;
  padding: 16px;
  overflow: hidden;
}

.stat-value {
  font-size: 28px;
  font-weight: 700;
  line-height: 1.2;
}

.stat-label {
  font-size: 13px;
  color: var(--text-tertiary);
  margin-top: 4px;
}

.stat-icon {
  position: absolute;
  right: 12px;
  top: 12px;
  width: 32px;
  height: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
}

/* 区域标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.section-more {
  font-size: 13px;
  color: var(--color-primary-light);
}

/* 事件卡片列表 */
.event-card {
  background: rgba(30, 39, 80, 0.4);
  border: 1px solid rgba(140, 155, 240, 0.15);
  border-radius: 10px;
  padding: 14px;
  margin-bottom: 10px;
}

.event-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.event-platform {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 4px;
  background: rgba(107, 114, 128, 0.12);
  color: var(--text-tertiary);
}

.event-title {
  font-size: 14px;
  color: var(--text-primary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-all;
}

.event-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8px;
}

.event-author {
  font-size: 12px;
  color: var(--text-tertiary);
}

.event-time {
  font-size: 12px;
  color: var(--text-disabled);
}

/* 空状态 */
.empty-state {
  padding: 40px 0;
  text-align: center;
}

.empty-text {
  font-size: 14px;
  color: var(--text-disabled);
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  gap: 12px;
  margin-top: 20px;
  padding-bottom: 20px;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(30, 39, 80, 0.4);
  border: 1px solid rgba(140, 155, 240, 0.15);
  border-radius: 12px;
  padding: 16px 0;
}

.action-icon {
  font-size: 24px;
  margin-bottom: 6px;
}

.action-label {
  font-size: 12px;
  color: var(--text-secondary);
}

/* 标签 */
.tag-positive {
  color: #10B981;
  background: rgba(16, 185, 129, 0.12);
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
}

.tag-negative {
  color: #EF4444;
  background: rgba(239, 68, 68, 0.12);
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
}

.tag-neutral {
  color: #9CA3AF;
  background: rgba(107, 114, 128, 0.12);
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
}
