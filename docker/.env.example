# Docker Compose 部署的环境变量
# 复制本文件为 .env 并填入真实值（docker compose 会自动加载）

# MySQL
DB_ROOT_PASSWORD=rootpass_change_me
DB_DATABASE=opinion_monitor
DB_USERNAME=opinion
DB_PASSWORD=opinionpass_change_me
DB_PORT=3306

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass_change_me

# JWT 和加密密钥（务必替换为强随机值）
# 生成方式：openssl rand -base64 32
JWT_SECRET=replace-with-random-string-min-32-chars
AES_ENCRYPTION_KEY=replace-with-base64-32-bytes-key

# 各平台聚合 API（可选，按需配置）
WEIBO_API_BASE=
WEIBO_API_KEY=
WEIXIN_API_BASE=
WEIXIN_API_KEY=
WEIXIN_VIDEO_API_BASE=
WEIXIN_VIDEO_API_KEY=
DOUYIN_API_BASE=
DOUYIN_API_KEY=
XIAOHONGSHU_API_BASE=
XIAOHONGSHU_API_KEY=
KUAISHOU_API_BASE=
KUAISHOU_API_KEY=
BAIJIAHAO_API_BASE=
BAIJIAHAO_API_KEY=
