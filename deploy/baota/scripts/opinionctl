#!/bin/bash
#
# opinionctl - 全网舆情监测系统部署控制命令
# 受控白名单操作入口，由部署控制台 API 调用
#

set -euo pipefail

RUNTIME_ROOT="${RUNTIME_ROOT:-/www/server/opinion-monitor}"
SITE_ROOT="${SITE_ROOT:-/www/wwwroot/opinion-monitor}"
COMPOSE_DIR="$RUNTIME_ROOT/compose"
LOG_DIR="$RUNTIME_ROOT/logs"

# 日志函数
log_info() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] [INFO] $*" | tee -a "$LOG_DIR/opinionctl.log"
}

log_error() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] [ERROR] $*" | tee -a "$LOG_DIR/opinionctl.log" >&2
}

# 检查权限
check_root() {
  if [[ $EUID -ne 0 ]]; then
    log_error "需要 root 权限"
    exit 1
  fi
}

# 获取容器状态
get_status() {
  cd "$COMPOSE_DIR"

  local mysql_status=$(docker compose ps mysql --format json 2>/dev/null | jq -r '.[0].State // "not_found"')
  local redis_status=$(docker compose ps redis --format json 2>/dev/null | jq -r '.[0].State // "not_found"')
  local backend_status=$(docker compose ps backend --format json 2>/dev/null | jq -r '.[0].State // "not_found"')

  cat <<EOF
{
  "mysql": "$mysql_status",
  "redis": "$redis_status",
  "backend": "$backend_status",
  "timestamp": "$(date -Iseconds)"
}
EOF
}

# 健康检查
health_check() {
  cd "$COMPOSE_DIR"

  local mysql_health="unknown"
  local redis_health="unknown"
  local backend_health="unknown"

  # MySQL 健康检查
  if docker compose ps mysql --format json 2>/dev/null | jq -e '.[0].Health == "healthy"' &>/dev/null; then
    mysql_health="healthy"
  elif docker compose ps mysql --format json 2>/dev/null | jq -e '.[0].State == "running"' &>/dev/null; then
    mysql_health="starting"
  else
    mysql_health="unhealthy"
  fi

  # Redis 健康检查
  if docker compose ps redis --format json 2>/dev/null | jq -e '.[0].Health == "healthy"' &>/dev/null; then
    redis_health="healthy"
  elif docker compose ps redis --format json 2>/dev/null | jq -e '.[0].State == "running"' &>/dev/null; then
    redis_health="starting"
  else
    redis_health="unhealthy"
  fi

  # 后端健康检查
  if docker compose ps backend --format json 2>/dev/null | jq -e '.[0].Health == "healthy"' &>/dev/null; then
    backend_health="healthy"
  elif docker compose ps backend --format json 2>/dev/null | jq -e '.[0].State == "running"' &>/dev/null; then
    backend_health="starting"
  else
    backend_health="unhealthy"
  fi

  cat <<EOF
{
  "mysql": "$mysql_health",
  "redis": "$redis_health",
  "backend": "$backend_health",
  "timestamp": "$(date -Iseconds)"
}
EOF
}

# 启动服务
start_services() {
  check_root
  log_info "启动服务..."

  cd "$COMPOSE_DIR"
  docker compose up -d

  log_info "服务已启动"
}

# 停止服务
stop_services() {
  check_root
  log_info "停止服务..."

  cd "$COMPOSE_DIR"
  docker compose stop

  log_info "服务已停止"
}

# 重启服务
restart_services() {
  check_root
  log_info "重启服务..."

  cd "$COMPOSE_DIR"
  docker compose restart

  log_info "服务已重启"
}

# 查看日志
view_logs() {
  local service="${1:-}"
  local lines="${2:-100}"

  cd "$COMPOSE_DIR"

  if [[ -n "$service" ]]; then
    docker compose logs --tail="$lines" "$service"
  else
    docker compose logs --tail="$lines"
  fi
}

# 构建并发布版本
release_application() {
  check_root
  local version="${1:-}"
  if [[ -n "$version" ]]; then
    "$RUNTIME_ROOT/scripts/build-release.sh" "$version"
  else
    "$RUNTIME_ROOT/scripts/build-release.sh"
  fi
}

# 首次初始化数据库与应用
bootstrap_application() {
  check_root
  "$RUNTIME_ROOT/scripts/bootstrap-app.sh"
}

# 备份数据库与配置
backup_database() {
  check_root
  local backup_id="${1:-}"
  if [[ -n "$backup_id" ]]; then
    "$RUNTIME_ROOT/scripts/backup-database.sh" "$backup_id"
  else
    "$RUNTIME_ROOT/scripts/backup-database.sh"
  fi
}

# 回滚应用（前端 + 后端）
rollback_application() {
  check_root
  local version="${1:-}"
  if [[ -z "$version" ]]; then
    log_error "回滚需要指定版本号"
    exit 1
  fi
  "$RUNTIME_ROOT/scripts/rollback-application.sh" "$version"
}

# 恢复数据库
restore_database() {
  check_root
  local backup_id="${1:-}"
  if [[ -z "$backup_id" ]]; then
    log_error "恢复需要指定备份ID"
    exit 1
  fi
  "$RUNTIME_ROOT/scripts/restore-database.sh" "$backup_id"
}

# 显示帮助
show_help() {
  cat <<EOF
opinionctl - 全网舆情监测系统部署控制命令

用法: opinionctl <命令> [参数]

命令:
  status              获取容器状态（JSON）
  health              执行健康检查（JSON）
  start               启动所有服务
  stop                停止所有服务
  restart             重启所有服务
  logs [服务] [行数]   查看容器日志（默认所有服务，最近 100 行）
  release [版本号]     构建并发布应用（后端镜像 + 前端静态资源）
  bootstrap           首次初始化数据库与应用
  backup [备份ID]      备份数据库与配置（默认使用时间戳）
  rollback <版本号>    回滚应用到指定版本（前端 + 后端）
  restore <备份ID>     恢复数据库（恢复前自动创建快照）
  help                显示帮助信息

示例:
  opinionctl status
  opinionctl health
  opinionctl start
  opinionctl logs backend 50
  opinionctl release 20260722001
  opinionctl bootstrap
  opinionctl backup
  opinionctl rollback 20260722001
  opinionctl restore 20260722120000
EOF
}

# 主函数
main() {
  local command="${1:-help}"

  case "$command" in
    status)
      get_status
      ;;
    health)
      health_check
      ;;
    start)
      start_services
      ;;
    stop)
      stop_services
      ;;
    restart)
      restart_services
      ;;
    logs)
      view_logs "${2:-}" "${3:-100}"
      ;;
    release)
      release_application "${2:-}"
      ;;
    bootstrap)
      bootstrap_application
      ;;
    backup)
      backup_database "${2:-}"
      ;;
    rollback)
      rollback_application "${2:-}"
      ;;
    restore)
      restore_database "${2:-}"
      ;;
    help|--help|-h)
      show_help
      ;;
    *)
      log_error "未知命令: $command"
      show_help
      exit 1
      ;;
  esac
}

main "$@"
