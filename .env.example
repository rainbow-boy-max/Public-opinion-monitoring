# 全网舆情监测系统 - 环境变量示例
# 复制本文件为 .env 并填入真实值，.env 文件不要提交到 git

# 应用配置
NODE_ENV=development
PORT=3000

# MySQL 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=opinion_monitor
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置（用于签发和校验 Token）
JWT_SECRET=replace-with-strong-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# AES-256-CBC 加密密钥（32 字节 base64，用于加密阿里云凭据等敏感字段）
# 生成命令：openssl rand -base64 32
AES_ENCRYPTION_KEY=replace-with-base64-32-bytes-key

# 前端配置
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=/
